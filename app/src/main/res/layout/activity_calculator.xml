<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <TextView
        android:id="@+id/display"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:text="0"
        android:textSize="72sp"
        android:textColor="#FFFFFF"
        android:gravity="bottom|end"
        android:padding="24dp"
        android:fontFamily="sans-serif-light"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="5"
        android:orientation="vertical"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <Button android:id="@+id/btnClear" style="@style/CalcBtnGray" android:text="AC"/>
            <Button android:id="@+id/btnPlusMinus" style="@style/CalcBtnGray" android:text="+/-"/>
            <Button android:id="@+id/btnPercent" style="@style/CalcBtnGray" android:text="%"/>
            <Button android:id="@+id/btnDiv" style="@style/CalcBtnOrange" android:text="÷"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <Button android:id="@+id/btn7" style="@style/CalcBtnDark" android:text="7"/>
            <Button android:id="@+id/btn8" style="@style/CalcBtnDark" android:text="8"/>
            <Button android:id="@+id/btn9" style="@style/CalcBtnDark" android:text="9"/>
            <Button android:id="@+id/btnMul" style="@style/CalcBtnOrange" android:text="×"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <Button android:id="@+id/btn4" style="@style/CalcBtnDark" android:text="4"/>
            <Button android:id="@+id/btn5" style="@style/CalcBtnDark" android:text="5"/>
            <Button android:id="@+id/btn6" style="@style/CalcBtnDark" android:text="6"/>
            <Button android:id="@+id/btnSub" style="@style/CalcBtnOrange" android:text="−"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <Button android:id="@+id/btn1" style="@style/CalcBtnDark" android:text="1"/>
            <Button android:id="@+id/btn2" style="@style/CalcBtnDark" android:text="2"/>
            <Button android:id="@+id/btn3" style="@style/CalcBtnDark" android:text="3"/>
            <Button android:id="@+id/btnAdd" style="@style/CalcBtnOrange" android:text="+"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <Button android:id="@+id/btn0" style="@style/CalcBtnDark"
                android:layout_width="0dp"
                android:layout_weight="2"
                android:text="0"
                android:gravity="center_vertical|start"
                android:paddingStart="28dp"/>
            <Button android:id="@+id/btnDot" style="@style/CalcBtnDark" android:text="."/>
            <Button android:id="@+id/btnEqual" style="@style/CalcBtnOrange" android:text="="/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
